{
  "service": {
    "name": "api-gateway",
    "limits": {"rps": 100, "burst": {"size": 200, "window_ms": 1000}},
    "routes": [
      {"path": "/v1/users", "methods": ["GET", "POST"], "auth": {"scopes": ["read", "write"]}},
      {"path": "/v1/health", "methods": ["GET"], "auth": null}
    ]
  }
}
